{
  "name": "mamba-sdk",
  "version": "3.0.0-alpha",
  "description": "SDK for developing in the Stone POS Mamba environment",
  "repository": "https://github.com/stone-payments/pos-mamba-sdk.git",
  "author": "Stone Payments",
  "license": "Apache-2.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "configs/*"
  ],
  "engines": {
    "node": ">=10.x"
  },
  "scripts": {
    "commit": "cz",
    "postinstall": "lerna bootstrap --ignore packages",
    "lint": "eslint '{tools,packages,configs}/**/*.{js,ts,svelte}' --quiet --fix",
    "lint:styles": "stylelint **/*.{css,scss,html,svelte,svg}"
  },
  "dependencies": {
    "@tsconfig/svelte": "^1.0.10",
    "eslint": ">=6.0.0",
    "git-cz": "^4.7.6",
    "husky": "^4.3.8",
    "lerna": "^3.22.1",
    "lint-staged": "^10.5.3",
    "prettier": "^2.2.1",
    "svelte": "^3.37.0",
    "typescript": "^4.2.4"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
    }
  },
  "lint-staged": {
    "*.{html,svelte}": [
      "stylelint --fix"
    ],
    "*.js": [
      "prettier --write",
      "eslint"
    ],
    "*.{pcss,css}": [
      "prettier --write",
      "stylelint --fix"
    ],
    "*.md": [
      "prettier --write"
    ]
  },
  "config": {
    "commitizen": {
      "path": "git-cz"
    }
  }
}
