{
  "name": "mamba-sdk",
  "version": "3.0.0-alpha",
  "description": "SDK for developing in the Stone POS Mamba environment",
  "repository": "https://github.com/stone-payments/pos-mamba-sdk.git",
  "author": "Stone Payments",
  "license": "Apache-2.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "configs/*"
  ],
  "engines": {
    "node": ">=10.x"
  },
  "scripts": {
    "commit": "cz",
    "lint": "eslint '{tools,packages}/**/*.{js,ts,tsx}' --quiet --fix",
    "lint:styles": "stylelint **/*.{css,scss,html,svelte,svg}"
  },
  "dependencies": {
    "commitlint-config-mamba": "file:./configs/commitlint-config-mamba",
    "eslint": ">=6.0.0",
    "eslint-config-prettier": "^8.1.0",
    "git-cz": "^4.7.6",
    "husky": "^4.3.8",
    "lerna": "^3.22.1",
    "lint-staged": "^10.5.3",
    "prettier": "^2.2.1",
    "prettier-config-mamba": "file:./configs/prettier-config-mamba",
    "stylelint": "^13.12.0"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
    }
  },
  "lint-staged": {
    "*.{html,svelte}": [
      "stylelint --fix"
    ],
    "*.js": [
      "prettier --write",
      "eslint"
    ],
    "*.{pcss,css}": [
      "prettier --write",
      "stylelint --fix"
    ],
    "*.md": [
      "prettier --write"
    ]
  },
  "config": {
    "commitizen": {
      "path": "git-cz"
    }
  }
}
