{
  "lerna": "3.22.0",
  "npmClient": "yarn",
  "npmClientArgs": ["--frozen-lockfile"],
  "useWorkspaces": true,
  "version": "independent",
  "ignoreChanges": [
    "**/__fixtures__/**",
    "**/__tests__/**",
    "**/docs/**",
    "**/e2e/**",
    "**/examples/**",
    "**/example/**",
    "**/*.md"
  ]
}
